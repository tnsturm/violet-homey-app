{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/check-version-sync.js" },
          { "type": "command", "command": "node .claude/hooks/typecheck-gate.js" },
          { "type": "command", "command": "node .claude/hooks/test-gate.js" },
          { "type": "command", "command": "node .claude/hooks/release-gate.js" },
          { "type": "command", "command": "node .claude/hooks/package-guard.js" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/secrets-guard.js" },
          { "type": "command", "command": "node .claude/hooks/compose-guard.js" },
          { "type": "command", "command": "node .claude/hooks/package-guard.js" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/run-matching-test.js" },
          { "type": "command", "command": "node .claude/hooks/json-guard.js" },
          { "type": "command", "command": "node .claude/hooks/dashboard-guard.js" },
          { "type": "command", "command": "node .claude/hooks/changelog-lang-guard.js" },
          { "type": "command", "command": "node .claude/hooks/docs-header-guard.js" },
          { "type": "command", "command": "node .claude/hooks/control-bytes-guard.js" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/stop-verify.js" }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git merge-base *)",
      "Bash(homey whoami)",
      "Bash(homey api devices get-*)",
      "Bash(homey api flow get-*)",
      "Bash(homey api logic get-*)",
      "Bash(homey api apps get-*)",
      "Bash(homey api flowtoken get-*)",
      "Bash(homey api zones get-*)",
      "Bash(homey api notifications get-*)",
      "Bash(npx homey api devices get-*)",
      "Bash(npx homey api apps get-*)",
      "Bash(homey app validate *)",
      "Bash(npx homey app validate *)",
      "Bash(git fetch *)",
      "Bash(claude plugin list)",
      "Bash(npm test)",
      "Bash(npm run typecheck)",
      "Bash(npx tsc -p tsconfig.checkjs.json)",
      "Bash(homey select current)",
      "Bash(curl -s --max-time 10 \"http://violet/get*)",
      "Bash(curl -s -m 10 \"http://violet/get*)",
      "Bash(curl -s --max-time 15 \"http://violet/get*)",
      "mcp__github__search_code"
    ]
  },
  "disableSkillShellExecution": true
}
