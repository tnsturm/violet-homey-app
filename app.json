                "de": "Aus deinem PoolLab/Test. Für den LSI erforderlich."
              }
            },
            {
              "id": "chem_alkalinity_unit",
              "type": "dropdown",
              "label": {
                "en": "Total alkalinity unit",
                "de": "Einheit Gesamtalkalität"
