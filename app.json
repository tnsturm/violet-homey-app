              ]
            },
            {
              "id": "chem_cya",
              "type": "number",
              "label": {
                "en": "Cyanuric acid (CYA, ppm)",
                "de": "Cyanursäure (CYA, ppm)"
              },
              "value": 0,
              "hint": {
                "en": "0 if unstabilised. Used for the pH-dependent alkalinity correction.",
                "de": "0 wenn unstabilisiert. Für die pH-abhängige Alkalitäts-Korrektur."
