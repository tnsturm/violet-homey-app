// Checker-only config for `npm run typecheck` (M4.5, Pfad A — evaluation doc §4A/§6:
// docs/superpowers/notes/2026-07-08-typescript-migration-evaluation.md).
// Deliberately NOT named tsconfig.json: its presence flips the Homey CLI into TS mode
// and `validate` then fails without a build script (doc §1, spike-verified).
// `types` is explicit because TS 6 no longer auto-includes installed @types (doc §1 gotcha).
// TypeScript itself is installed under the npm alias "typescript-checkjs": homey-cli 4.1.1
// keys its TS mode on `devDependencies.typescript` (not on tsconfig presence — doc §1
// Nachtrag 2026-07-08); the literal name would break validate/build/run/install.
// strict:true since M5 (2026-07-10, gate c): the checkJs-strict ratchet was exhausted —
// lib/ + drivers/ + test/ are strict-clean (RawReadings/Features/ParsedReadings typedefs,
// see evaluation doc §5 Nachtrag). Do NOT weaken back to false (M5 gate c invariant).
{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "module": "node18",
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["node", "homey"],
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["app.js", "lib/**/*.js", "drivers/**/*.js", "test/**/*.js"]
}
